    opacity: 0;
    transition: opacity 0.3s ease;
}

.quote-modal.active {
    display: flex;
    opacity: 1;
}

.quote-modal-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(5px);
}

