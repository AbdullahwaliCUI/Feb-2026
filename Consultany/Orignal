 <!-- Mobile Menu Toggle Script -->     <script type='text/javascript'>
//<![CDATA[
    document.addEventListener('DOMContentLoaded', function() {
        const mobileMenuToggle = document.getElementById('mobile-menu-toggle');
        const navMenu = document.getElementById('nav-menu');
        const body = document.body;

        function closeMenu() {
            navMenu.classList.remove('active');
            mobileMenuToggle.classList.remove('active');
            body.style.overflow = '';
        }

        function openMenu() {
            navMenu.classList.add('active');
            mobileMenuToggle.classList.add('active');
            body.style.overflow = 'hidden';
        }

        if (mobileMenuToggle && navMenu) {
            mobileMenuToggle.addEventListener('click', function(e) {
                e.stopPropagation();
                if (navMenu.classList.contains('active')) {
                    closeMenu();
                } else {
                    openMenu();
                }
            });

            const navLinks = navMenu.querySelectorAll('a');
            navLinks.forEach(function(link) {
                link.addEventListener('click', function() { closeMenu(); });
            });

            document.addEventListener('click', function(e) {
                if (navMenu.classList.contains('active')) {
                    if (!navMenu.contains(e.target) && !mobileMenuToggle.contains(e.target)) {
                        closeMenu();
                    }
                }
            });

            document.addEventListener('keydown', function(e) {
                if (e.key === 'Escape' && navMenu.classList.contains('active')) {
                    closeMenu();
                }
            });

            navMenu.addEventListener('touchmove', function(e) {
                if (navMenu.classList.contains('active')) {
                    e.stopPropagation();
                }
            }, { passive: false });
        }
    });
//]]>
</script>
 <!-- Service Detail Script -->     <script type='text/javascript'>
//<![CDATA[
    document.addEventListener('DOMContentLoaded', function() {
        const body = document.body;
        const currentPath = window.location.pathname;
        const currentUrl = window.location.href;

        const servicePageMap = {
            'structural-engineering': 'service-structural-engineering',
            'civil-engineering': 'service-civil-engineering',
            'consulting-services': 'service-consulting-services'
        };

        let isServicePage = false;
        let serviceId = null;

        for (const serviceKey in servicePageMap) {
            // Only trigger if we are on a static page path (/p/) to avoid hijacking blog posts with similar names
            if ((currentPath.includes('/p/') || currentUrl.includes('/p/')) && 
                (currentPath.includes(serviceKey) || currentUrl.includes(serviceKey))) {
                isServicePage = true;
                serviceId = servicePageMap[serviceKey];
                break;
            }
        }

        if (isServicePage && serviceId) {
            body.classList.add('service-page');
            document.querySelectorAll('.service-detail-section').forEach(function(section) {
                section.style.display = 'none';
                section.classList.remove('active', 'service-active');
            });
            const serviceDetailSection = document.getElementById(serviceId);
            if (serviceDetailSection) {
                serviceDetailSection.classList.add('service-active');
                serviceDetailSection.style.display = 'block';
            }
        } else {
            let currentServiceDetailSection = null;
            const serviceCardLinks = document.querySelectorAll('.service-card-link');
            serviceCardLinks.forEach(function(link) {
                link.addEventListener('click', function(e) {
                    const href = this.getAttribute('href');
