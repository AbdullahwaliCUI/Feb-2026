    Times New Roman&#39;
    ,
    serif;
    color: #ffffff;
    text-align: center;
    margin: 0 0 50px 0;
    text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5);
    display: block !important;
    visibility: visible !important;
}

.pictures-grid {
    display: grid !important;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 30px;
    margin-top: 40px;
    visibility: visible !important;
}

.picture-card {
    background: linear-gradient(135deg, #000000, #000000);
    border-radius: 15px;
    overflow: hidden;
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
    transition: all 0.3s ease;
    border: 1px solid #000000;
    position: relative;
    display: block !important;
    visibility: visible !important;
}

.picture-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.4);
    border-color: #ffd700;
}

.picture-image {
    width: 100%;
    height: 250px;
    object-fit: cover;
    object-position: center;
    background: linear-gradient(135deg, #000000, #000000);
    transition: transform 0.3s ease;
    display: block !important;
    visibility: visible !important;
}



.picture-card:hover .picture-image {
    transform: scale(1.05);
}

.picture-content {
    padding: 25px;
    text-align: center;
}

.picture-title {
    font: bold 20px &#39;
    Arial&#39;
    ,
    sans-serif;
    color: #ffd700;
    margin: 0 0 15px 0;
    transition: color 0.3s ease;
}

.picture-card:hover .picture-title {
    color: #ffd700;
}

.picture-description {
    font: 14px &#39;
    Arial&#39;
    ,
    sans-serif;
    color: #ffffff;
    line-height: 1.6;
    margin: 0;
}

/* Hide other sections on pictures page */
.pictures-page .consulting-hero,
.pictures-page .consulting-about,
.pictures-page .consulting-services,
.pictures-page .consulting-contact,
.pictures-page .blog-section {
    display: none !important;
}

/* Hide pictures section on home page */
.pictures-section {
    display: none !important;
}

/* Show pictures section only on pictures page */
.pictures-page .pictures-section {
    display: block !important;
}

/* Videos Page Styling */
.videos-page {
    background: linear-gradient(135deg, #000000 0%, #000000 50%, #000000 100%);
    padding: 40px 0;
    min-height: 100vh;
}

.videos-section {
    display: none;
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 20px;
}

.videos-container {
    text-align: center;
}

.videos-container h2 {
    color: #ffffff;
    font-size: 2.5rem;
    margin-bottom: 20px;
    text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5);
}

.videos-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 30px;
    margin-top: 40px;
    visibility: visible !important;
}

.video-card {
    background: linear-gradient(135deg, #000000, #000000);
    border-radius: 15px;
    overflow: hidden;
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
    transition: all 0.3s ease;
    border: 2px solid transparent;
    position: relative;
    display: block !important;
    visibility: visible !important;
}

.video-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.4);
    border-color: #ffd700;
}

.video-embed {
    width: 100%;
    height: 200px;
    border: none;
    display: block !important;
    visibility: visible !important;
}

.video-card:hover .video-embed {
    transform: scale(1.02);
}

.video-content {
    padding: 25px;
    text-align: left;
}

.video-title {
    font: 18px &#39;
    Arial&#39;
    ,
    sans-serif;
    font-weight: bold;
    color: #ffd700;
    margin: 0 0 15px 0;
