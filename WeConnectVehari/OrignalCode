  updateCardsPerView();
  totalSlides=Math.ceil(totalCards / cardsPerView);

  const slider=document.getElementById('teamSlider');
  const cardWidth=slider.children[0].offsetWidth+24; // card width + gap

  currentSlideIndex+=direction;

  // Keep within bounds
