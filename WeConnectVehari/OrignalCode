// Modal Functions
function showTeamMemberDetails(memberId) {
  const member=teamMemberData[memberId];
  if ( !member) return;

  // Update modal content
  document.getElementById('modalIcon').className=member.icon;
  document.getElementById('modalName').textContent=member.name;
  document.getElementById('modalRole').textContent=member.role;
  document.getElementById('modalTagline').textContent=member.tagline;
  document.getElementById('modalExperience').textContent=member.experience;

  // Update skills
  const skillsContainer=document.getElementById('modalSkills');
  skillsContainer.innerHTML='';

  member.skills.forEach(skill=> {
      const skillBadge=document.createElement('span');
      skillBadge.className='skill-badge';
      skillBadge.textContent=skill;
      skillsContainer.appendChild(skillBadge);
    });

  // Update links
  const linksContainer=document.getElementById('modalLinks');
  linksContainer.innerHTML='';

  member.links.forEach(link=> {
      const linkElement=document.createElement('a');
      linkElement.href=link.url;
      linkElement.target='_blank';

      linkElement.className=`modal-link $ {
        link.class
      }

      `;

      linkElement.innerHTML=`<i class="${link.icon}" ></i>$ {
        link.name
      }

      `;
      linksContainer.appendChild(linkElement);
    });

  // Show modal
  const overlay=document.getElementById('teamModalOverlay');
  overlay.classList.add('show');
  document.body.style.overflow='hidden';
}

function closeTeamModal() {
  const overlay=document.getElementById('teamModalOverlay');
  overlay.classList.remove('show');
  document.body.style.overflow='auto';
}

