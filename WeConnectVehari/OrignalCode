  color: white;
  padding: 1rem 2rem;
  border-radius: 50px;
  box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
  display: none;
  z-index: 9999;
  animation: slideUp 0.5s ease-out;
}

@keyframes slideUp {
  from {
    transform: translate(-50%, 100%);
    opacity: 0;
  }

  to {
    transform: translate(-50%, 0);
    opacity: 1;
  }
}

.error-message {
  background: rgba(220, 53, 69, 0.9);
}

