      0% 55%,
      10% 50%,
      20% 55%,
      30% 50%,
      40% 55%,
      50% 50%,
      60% 55%,
      70% 50%,
      80% 55%,
      90% 50%,
      100% 55%,
      100% 0%);
  animation: waveFloat 4s ease-in-out infinite;
}

.wave-divider.reverse::after {
  clip-path: polygon(0% 0%,
