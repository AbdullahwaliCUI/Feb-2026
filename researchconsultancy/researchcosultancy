  <!-- Bootstrap JS -->
  <script crossorigin='anonymous' integrity='sha384-YvpcrYf0tY3lHB60NNkmxc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz' src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js'></script>
  
  <script>
    //<![CDATA[
    // Smooth scrolling for anchor links with offset for sticky navbar
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
            e.preventDefault();
            
            // Close mobile menu if open
            const collapseElement = document.getElementById('navbarNav');
            if (collapseElement && collapseElement.classList.contains('show')) {
                document.querySelector('.navbar-toggler').click();
            }

            const targetId = this.getAttribute('href');
            if(targetId === '#') return;
            const targetElement = document.querySelector(targetId);
            if(targetElement) {
              const headerOffset = 80;
              const elementPosition = targetElement.getBoundingClientRect().top;
              const offsetPosition = elementPosition + window.pageYOffset - headerOffset;
  
              window.scrollTo({
                   top: offsetPosition,
                   behavior: "smooth"
              });
            }
        });
    });
    
    // Navbar scroll effect
    window.addEventListener('scroll', function() {
        const navbar = document.querySelector('.navbar-custom');
        if (window.scrollY > 50) {
            navbar.style.padding = '10px 0';
            navbar.style.background = 'rgba(255, 255, 255, 0.95)';
        } else {
            navbar.style.padding = '18px 0';
            navbar.style.background = 'rgba(255, 255, 255, 0.85)';
        }
    });

    // Simple scroll trigger for animations (so they trigger when scrolled into view)
    const observerOptions = {
        root: null,
        rootMargin: '0px',
        threshold: 0.1
    };

    const observer = new IntersectionObserver((entries, observer) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.style.visibility = 'visible';
                entry.target.classList.add('animate__animated');
                observer.unobserve(entry.target);
            }
        });
    }, observerOptions);

    // Initial setup: hide wow elements
    document.addEventListener('DOMContentLoaded', () => {
        const animatedElements = document.querySelectorAll('.wow');
        animatedElements.forEach(el => {
            el.style.visibility = 'hidden';
            // We temporarily remove the class so the observer re-adds it to trigger the animation
            el.classList.remove('animate__animated'); 
            observer.observe(el);
        });
    });
    
    // FormSubmit AJAX Handler (Prevents Default Redirection FormSubmit Screen)
    document.getElementById('contactForm').addEventListener('submit', function(e) {
        e.preventDefault(); // Prevent standard redirect
        
        const form = e.target;
        const formMessage = document.getElementById('formMessage');
        const submitBtn = form.querySelector('button[type="submit"]');
        const btnText = submitBtn.querySelector('span');
        const btnIcon = submitBtn.querySelector('i');
        
        // Save original text and update to loading state
        const originalText = btnText.innerText;
        btnText.innerText = 'Sending...';
        btnIcon.className = 'fas fa-spinner fa-spin ms-2';
        submitBtn.disabled = true;

        fetch(form.action, {
            method: 'POST',
            body: new FormData(form),
            headers: {
                'Accept': 'application/json'
            }
        }).then(response => {
            if (response.ok) {
                // Success
                formMessage.innerHTML = '<div class="alert alert-success border-0 shadow-sm rounded-pill py-3"><strong><i class="fas fa-check-circle me-2"></i>Thanks for Contacting us!</strong> We will get back to you soon.</div>';
                form.reset(); // Clear the form
            } else {
                // Error from FormSubmit Server
                formMessage.innerHTML = '<div class="alert alert-warning border-0 shadow-sm rounded-pill py-3"><i class="fas fa-exclamation-triangle me-2"></i>Oops! There was a problem submitting your form.</div>';
            }
        }).catch(error => {
            // General Error
            formMessage.innerHTML = '<div class="alert alert-danger border-0 shadow-sm rounded-pill py-3"><i class="fas fa-exclamation-triangle me-2"></i>Oops! There was a problem submitting your form.</div>';
        }).finally(() => {
            // Reset Button State
            btnText.innerText = originalText;
            btnIcon.className = 'fas fa-paper-plane ms-2';
            submitBtn.disabled = false;
            
            // Clear message after 6 seconds
            setTimeout(() => {
                formMessage.innerHTML = '';
            }, 6000);
        });
    });
    //]]>
  </script>
