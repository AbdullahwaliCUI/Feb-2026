  <b:skin version='1.3.3'><![CDATA[
    /* Custom High-End CSS Variables and Styles */
    :root {
      /* Gradient & Accent palette */
      --primary-dark: #0f2027;
      --primary-mid: #203a43;
      --primary-light: #2c5364;
      
      --accent-gold: #c5a059;
      --accent-gold-dark: #b08d4b;
      --accent-gold-light: #dfb96f;
      
      /* Neutrals */
      --text-dark: #1a1a1a;
      --text-muted: #5a6673;
      --bg-light: #f4f6f9;
      --bg-white: #ffffff;
      
      /* Glassmorphism settings */
      --glass-bg: rgba(255, 255, 255, 0.85);
      --glass-border: rgba(255, 255, 255, 0.4);
      --glass-shadow: 0 8px 32px 0 rgba(15, 32, 39, 0.08);
      
      /* Radii */
      --radius-sm: 8px;
      --radius-md: 16px;
      --radius-lg: 24px;
      --radius-pill: 50px;
    }
    
    /* Global Styles */
    body {
      font-family: 'Inter', sans-serif;
      background-color: var(--bg-light);
      color: var(--text-dark);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      overflow-x: hidden;
    }
    
    h1, h2, h3, h4, h5, h6, .brand-font {
      font-family: 'Playfair Display', serif;
    }

    /* CSS Animations for Gradients */
    @keyframes gradientBG {
      0% {
        background-position: 0% 50%;
      }
      50% {
        background-position: 100% 50%;
      }
      100% {
        background-position: 0% 50%;
      }
    }

    /* Floating Data Nodes Animation */
    .nodes-container {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      overflow: hidden;
      z-index: 0;
      pointer-events: none;
    }

    .node {
      position: absolute;
      background: rgba(255, 255, 255, 0.15);
      border-radius: 50%;
      box-shadow: 0 0 10px rgba(255, 255, 255, 0.2);
    }
    
    /* Node lines connecting them */
    .node::before {
        content: '';
        position: absolute;
        width: 150px;
        height: 1px;
        background: linear-gradient(90deg, rgba(255,255,255,0.1), transparent);
        top: 50%;
        left: 50%;
        transform-origin: 0 0;
    }

    .node:nth-child(1) { width: 8px; height: 8px; top: 20%; left: 10%; animation: float 12s infinite alternate ease-in-out; }
    .node:nth-child(1)::before { transform: rotate(45deg); width: 100px; }
    
    .node:nth-child(2) { width: 12px; height: 12px; top: 60%; left: 15%; animation: float 15s infinite alternate-reverse ease-in-out; }
    .node:nth-child(2)::before { transform: rotate(-25deg); width: 200px; }
    
    .node:nth-child(3) { width: 6px; height: 6px; top: 30%; left: 45%; animation: float 10s infinite alternate ease-in-out; }
    .node:nth-child(3)::before { transform: rotate(15deg); width: 150px; }
    
    .node:nth-child(4) { width: 10px; height: 10px; top: 70%; left: 60%; animation: float 18s infinite alternate-reverse ease-in-out; }
    .node:nth-child(4)::before { transform: rotate(-65deg); width: 180px; }
    
    .node:nth-child(5) { width: 15px; height: 15px; top: 40%; left: 80%; animation: float 14s infinite alternate ease-in-out; }
    .node:nth-child(5)::before { transform: rotate(120deg); width: 220px; }
    
    .node:nth-child(6) { width: 9px; height: 9px; top: 80%; left: 85%; animation: float 16s infinite alternate-reverse ease-in-out; }
    .node:nth-child(6)::before { transform: rotate(180deg); width: 120px; }
    
    .node:nth-child(7) { width: 5px; height: 5px; top: 10%; left: 60%; animation: float 11s infinite alternate ease-in-out; }
    .node:nth-child(7)::before { transform: rotate(90deg); width: 160px; }

    @keyframes float {
      0% { transform: translate(0, 0) scale(1); opacity: 0.3; }
      50% { opacity: 0.8; }
      100% { transform: translate(40px, -40px) scale(1.5); opacity: 0.3; }
    }
    
    /* Navbar (Glassmorphism) */
    .navbar-custom {
      background: var(--glass-bg);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--glass-border);
      box-shadow: var(--glass-shadow);
      padding: 18px 0;
      transition: all 0.3s ease;
    }
    .navbar-custom .navbar-brand {
      font-weight: 700;
      font-size: 1.6rem;
      /* Animated gradient text for brand */
      background: linear-gradient(90deg, var(--primary-dark), var(--primary-light), var(--primary-dark));
      background-size: 200% auto;
      color: transparent;
      -webkit-background-clip: text;
      background-clip: text;
      animation: gradientBG 4s linear infinite;
      letter-spacing: -0.5px;
      position: relative;
    }
    .navbar-custom .navbar-brand i {
      color: var(--accent-gold);
      -webkit-background-clip: initial;
      background-clip: initial;
      color: var(--accent-gold);
    }
    .navbar-custom .nav-link {
      font-family: 'Inter', sans-serif;
      font-weight: 500;
      font-size: 0.95rem;
      color: var(--text-dark) !important;
      padding: 0.5rem 1.2rem;
      transition: all 0.3s ease;
      position: relative;
    }
    .navbar-custom .nav-link::after {
      content: '';
      position: absolute;
      width: 0;
      height: 2px;
      bottom: 0px;
      left: 50%;
      background-color: var(--accent-gold);
      transition: all 0.3s ease;
      transform: translateX(-50%);
    }
    .navbar-custom .nav-link:hover {
      color: var(--accent-gold) !important;
    }
    .navbar-custom .nav-link:hover::after {
      width: 70%;
    }
    
    /* Premium Animated Button (CTA) */
    .btn-premium {
      background: linear-gradient(135deg, var(--accent-gold) 0%, var(--accent-gold-dark) 50%, var(--accent-gold) 100%);
      background-size: 200% auto;
      color: white !important;
      font-family: 'Inter', sans-serif;
      font-weight: 600;
      font-size: 0.95rem;
      letter-spacing: 0.5px;
      border-radius: var(--radius-pill);
      padding: 10px 24px;
      border: none;
      box-shadow: 0 8px 20px rgba(197, 160, 89, 0.4);
      transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
      position: relative;
      overflow: hidden;
    }
    .btn-premium:hover {
      transform: translateY(-3px);
      box-shadow: 0 12px 25px rgba(197, 160, 89, 0.5);
      background-position: right center; /* animate gradient on hover */
    }
    
    .btn-outline-premium {
      background: transparent;
      color: white !important;
      border: 2px solid rgba(255,255,255,0.8);
      font-weight: 600;
      border-radius: var(--radius-pill);
      padding: 10px 24px;
      transition: all 0.3s ease;
      backdrop-filter: blur(5px);
    }
    .btn-outline-premium:hover {
      background: white;
      color: var(--primary-dark) !important;
      transform: translateY(-3px);
      box-shadow: 0 10px 20px rgba(0,0,0,0.1);
    }

    /* Hero Section with Animated Gradient Background */
    .hero-section {
      /* Setup the animated shifting gradient */
      background: linear-gradient(-45deg, #0f2027, #203a43, #2c5364, #1f4037, #283c86);
      background-size: 400% 400%;
      animation: gradientBG 15s ease infinite;
      color: white;
      padding: 140px 0 160px;
      text-align: center;
      position: relative;
      overflow: hidden;
      z-index: 1;
    }
    /* Angled bottom clip-path */
    .hero-section::after {
      content: '';
      position: absolute;
      bottom: -1px; left: 0; right: 0;
      height: 80px;
      background: var(--bg-light);
      clip-path: polygon(0 100%, 100% 100%, 100% 0, 0 80%);
      z-index: 1;
    }
    
    .hero-content-wrapper {
        position: relative;
        z-index: 2; /* Needs to be above the animated nodes */
    }

    .hero-badge {
      display: inline-block;
      padding: 6px 16px;
      background: rgba(197, 160, 89, 0.15);
      border: 1px solid rgba(197, 160, 89, 0.3);
      color: var(--accent-gold-light);
      border-radius: var(--radius-pill);
      font-family: 'Inter', sans-serif;
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 1px;
      text-transform: uppercase;
      margin-bottom: 25px;
      animation: pulse 2s infinite;
    }
    @keyframes pulse {
        0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(197, 160, 89, 0.4); }
        70% { transform: scale(1.02); box-shadow: 0 0 0 10px rgba(197, 160, 89, 0); }
        100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(197, 160, 89, 0); }
    }

    .hero-title {
      font-weight: 700;
      font-size: 4.5rem;
      line-height: 1.1;
      margin-bottom: 25px;
      text-shadow: 0 10px 30px rgba(0,0,0,0.3);
      letter-spacing: -1px;
    }
    .hero-title span {
      background: linear-gradient(135deg, var(--accent-gold-light) 0%, var(--accent-gold) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .hero-subtitle {
      font-family: 'Inter', sans-serif;
      font-size: 1.25rem;
      font-weight: 300;
      color: rgba(255,255,255,0.85);
      max-width: 800px;
      margin: 0 auto 40px;
      line-height: 1.7;
    }
    
    /* Services Section (Elevated Cards with Entrance animations) */
    .services-section {
      padding: 100px 0;
      background-color: var(--bg-light);
      position: relative;
    }
    .section-title {
      font-weight: 700;
      font-size: 2.5rem;
      text-align: center;
      margin-bottom: 70px;
      color: var(--primary-dark);
      position: relative;
    }
    .section-title::after {
      content: '';
      position: absolute;
      bottom: -20px;
      left: 50%;
      transform: translateX(-50%);
      width: 40px;
      height: 3px;
      background: var(--accent-gold);
      border-radius: 2px;
    }
    .service-card {
      background: var(--bg-white);
      border-radius: var(--radius-md);
      padding: 50px 40px;
      height: 100%;
      transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
      box-shadow: 0 10px 40px -10px rgba(15, 32, 39, 0.08);
      border: 1px solid rgba(0,0,0,0.03);
      position: relative;
      z-index: 1;
      overflow: hidden;
    }
    /* Subtle background pulse on hover */
    .service-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background: radial-gradient(circle at top right, rgba(197, 160, 89, 0.05), transparent 40%);
        opacity: 0;
        transition: opacity 0.5s ease;
        z-index: -2;
    }
    .service-card::after {
      content: "";
      border-radius: var(--radius-md);
      position: absolute;
      top: 0; left: 0; right: 0; bottom: 0;
      box-shadow: 0 20px 40px -10px rgba(15, 32, 39, 0.15);
      opacity: 0;
      transition: opacity 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
      z-index: -1;
    }
    .service-card:hover {
      transform: translateY(-15px);
      border-color: rgba(197, 160, 89, 0.2);
    }
    .service-card:hover::after, .service-card:hover::before {
      opacity: 1;
    }
    .icon-wrapper {
      width: 70px;
      height: 70px;
      background: linear-gradient(135deg, rgba(197, 160, 89, 0.1) 0%, rgba(197, 160, 89, 0.05) 100%);
      border-radius: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 30px;
      transition: transform 0.4s ease, background 0.4s ease;
    }
    .service-card:hover .icon-wrapper {
      background: linear-gradient(135deg, var(--accent-gold) 0%, var(--accent-gold-dark) 100%);
      transform: scale(1.1) rotate(5deg);
    }
    .service-icon {
      font-size: 2rem;
      color: var(--accent-gold);
      transition: color 0.4s ease;
    }
    .service-card:hover .service-icon {
      color: white;
    }
    .service-title {
      font-weight: 700;
      font-size: 1.4rem;
      margin-bottom: 15px;
      color: var(--primary-dark);
      letter-spacing: -0.2px;
    }
    .service-card p {
      color: var(--text-muted);
      line-height: 1.7;
      font-size: 0.95rem;
    }
    
    /* Blog Section */
    .blog-section {
      padding: 100px 0;
      background-color: var(--bg-white);
    }
    
    /* Post Cards */
    .post-card {
      background: var(--bg-white);
      border-radius: var(--radius-md);
      box-shadow: 0 10px 40px -10px rgba(15, 32, 39, 0.05);
      border: 1px solid rgba(0,0,0,0.03);
      margin-bottom: 30px;
      overflow: hidden;
      transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
      height: 100%;
      display: flex;
      flex-direction: column;
    }
    .post-card:hover {
      transform: translateY(-10px);
      box-shadow: 0 20px 40px -10px rgba(15, 32, 39, 0.12);
    }
    .post-img-wrapper {
      position: relative;
      overflow: hidden;
    }
    .post-img {
      width: 100%;
      height: 220px;
      object-fit: cover;
      transition: transform 0.6s ease;
    }
    .post-card:hover .post-img {
      transform: scale(1.05);
    }
    .post-category {
      position: absolute;
      top: 15px;
      left: 15px;
      background: rgba(15, 32, 39, 0.8);
      backdrop-filter: blur(4px);
      color: white;
      font-size: 0.75rem;
      font-weight: 600;
      padding: 5px 12px;
      border-radius: var(--radius-pill);
      text-transform: uppercase;
      letter-spacing: 1px;
    }
    .post-content {
      padding: 30px;
      flex-grow: 1;
      display: flex;
      flex-direction: column;
    }
    .post-meta {
      font-size: 0.85rem;
      color: var(--text-muted);
      font-weight: 500;
      margin-bottom: 15px;
      display: flex;
      align-items: center;
    }
    .post-meta i {
      color: var(--accent-gold);
      margin-right: 6px;
    }
    .post-title {
      font-family: 'Playfair Display', serif;
      margin-bottom: 15px;
    }
    .post-title a {
      color: var(--primary-dark);
      font-weight: 700;
      text-decoration: none;
      font-size: 1.5rem;
      line-height: 1.3;
      transition: color 0.3s ease;
    }
    .post-title a:hover {
      color: var(--accent-gold);
    }
    .post-snippet {
      color: var(--text-muted);
      line-height: 1.6;
      font-size: 0.95rem;
      margin-bottom: 20px;
      flex-grow: 1;
    }
    .read-more {
      font-family: 'Inter', sans-serif;
      font-weight: 600;
      font-size: 0.9rem;
      color: var(--primary-mid);
      text-decoration: none;
      letter-spacing: 0.5px;
      text-transform: uppercase;
      display: inline-flex;
      align-items: center;
      transition: all 0.3s ease;
    }
    .read-more i {
      margin-left: 8px;
      font-size: 0.8rem;
      transition: transform 0.3s ease;
    }
    .read-more:hover {
      color: var(--accent-gold);
    }
    .read-more:hover i {
      transform: translateX(5px);
    }

    /* Single Post */
    .single-post-wrapper {
      background: white;
      border-radius: var(--radius-lg);
      box-shadow: 0 10px 50px -10px rgba(15, 32, 39, 0.08);
      padding: 50px;
      border: 1px solid rgba(0,0,0,0.03);
    }
    .single-post h1 {
      font-family: 'Playfair Display', serif;
      font-weight: 700;
      font-size: 3rem;
      color: var(--primary-dark);
      line-height: 1.2;
      margin-bottom: 20px;
    }
    .single-post-meta {
      font-family: 'Inter', sans-serif;
      font-size: 0.9rem;
      color: var(--text-muted);
      font-weight: 500;
      margin-bottom: 40px;
      padding-bottom: 20px;
      border-bottom: 1px solid #eaeaea;
    }
    .post-body {
      font-family: 'Inter', sans-serif;
      font-size: 1.05rem;
      line-height: 1.8;
      color: #333;
    }
    .post-body h2, .post-body h3 {
      font-family: 'Playfair Display', serif;
      color: var(--primary-dark);
      margin-top: 40px;
      margin-bottom: 20px;
    }
    .post-body blockquote {
      border-left: 4px solid var(--accent-gold);
      padding-left: 20px;
      margin: 30px 0;
      font-style: italic;
      color: var(--primary-mid);
      font-size: 1.2rem;
    }
    
    /* Pagination */
    .blog-pager {
      margin-top: 50px;
    }
    .blog-pager a {
      background: white;
      border: 1px solid #eaeaea;
      color: var(--primary-dark);
      padding: 12px 25px;
      border-radius: var(--radius-pill);
      font-weight: 600;
      font-size: 0.9rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      transition: all 0.3s ease;
      text-decoration: none;
    }
    .blog-pager a:hover {
      background: var(--primary-dark);
      color: white;
      border-color: var(--primary-dark);
    }

    /* Contact Section Customization */
    .contact-section {
        padding: 100px 0;
        background-color: var(--bg-light);
    }
    .contact-form-wrapper {
        background: var(--bg-white);
        border-radius: var(--radius-lg);
        box-shadow: 0 10px 40px -10px rgba(15, 32, 39, 0.08);
        padding: 50px;
        border: 1px solid rgba(0,0,0,0.03);
    }
    .contact-form-wrapper .form-control {
        border-radius: var(--radius-md);
        padding: 15px 20px;
        background-color: #f8fafc;
        border: 1px solid #e2e8f0;
        font-family: 'Inter', sans-serif;
        color: var(--text-dark);
        margin-bottom: 20px;
        transition: all 0.3s ease;
    }
    .contact-form-wrapper .form-control:focus {
        border-color: var(--accent-gold);
        box-shadow: 0 0 0 3px rgba(197, 160, 89, 0.15);
        background-color: white;
        outline: none;
    }
    .contact-form-wrapper textarea.form-control {
        min-height: 150px;
    }
    
    /* Footer */
    .footer {
      background-color: var(--primary-dark);
      color: rgba(255,255,255,0.7);
      padding: 80px 0 30px;
      position: relative;
    }
    .footer::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 4px;
      /* Animated gradient band at the top of the footer */
      background: linear-gradient(90deg, #c5a059, #dfb96f, #0f2027, #dfb96f);
      background-size: 200% 200%;
      animation: gradientBG 4s ease infinite;
    }
    .footer-brand {
      font-family: 'Playfair Display', serif;
      font-size: 1.8rem;
      font-weight: 700;
      color: white;
      margin-bottom: 25px;
      display: inline-block;
    }
    .footer-brand i { 
      color: var(--accent-gold);
    }
    .footer-heading {
      font-family: 'Playfair Display', serif;
      font-weight: 600;
      font-size: 1.2rem;
      color: white;
      margin-bottom: 25px;
      letter-spacing: 0.5px;
    }
    .footer-links a {
      color: rgba(255,255,255,0.7);
      text-decoration: none;
      transition: color 0.3s ease;
      font-size: 0.95rem;
      display: inline-block;
      margin-bottom: 12px;
    }
    .footer-links a:hover {
      color: var(--accent-gold);
      padding-left: 5px;
    }
    .social-links a {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: rgba(255,255,255,0.05);
      color: white;
      font-size: 1.1rem;
      margin-right: 15px;
      transition: all 0.3s ease;
    }
    .social-links a:hover {
      background: var(--accent-gold);
      transform: translateY(-3px) rotate(10deg);
    }
    .copyright {
      margin-top: 60px;
      padding-top: 30px;
      border-top: 1px solid rgba(255,255,255,0.1);
      text-align: center;
      font-size: 0.9rem;
    }

    /* Responsive adjustments */
    @media (max-width: 991px) {
      .hero-title { font-size: 3.2rem; }
      .section-title { font-size: 2.2rem; }
      .navbar-custom { padding: 10px 0; }
      .navbar-collapse {
        background: var(--bg-white);
        padding: 20px;
        border-radius: var(--radius-md);
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        margin-top: 15px;
        position: absolute;
        width: calc(100% - 24px);
        left: 12px;
        top: 100%;
        z-index: 1050;
      }
      .navbar-nav {
        align-items: flex-start !important;
      }
