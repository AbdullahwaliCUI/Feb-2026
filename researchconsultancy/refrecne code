  </b:section>

  <!-- Hero Section -->
  <section class='hero-section' id='home'>
    <div class='container'>
      <div class='row justify-content-center'>
        <div class='col-lg-10'>
          <h1 class='hero-title'>Expert Research Consultancy</h1>
          <p class='hero-subtitle'>Research consultancy traning to paper publish classes and compleet Guide with our expert researchers. each and everyting hum proideakry gy ,, machine learning and in appliend fileds. data set with complete work flow guidence.</p>
          <div class='mt-4'>
            <a class='btn btn-light btn-lg px-4 py-3 fw-bold me-3 shadow' href='#services'>Explore Services</a>
            <a class='btn btn-outline-light btn-lg px-4 py-3 fw-bold' href='#contact'><i class='fas fa-paper-plane me-2'></i>Contact Experts</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class='services-section' id='services'>
    <div class='container'>
      <h2 class='section-title'>What We Provide</h2>
      <div class='row g-4 mt-2'>
        <div class='col-md-4'>
          <div class='service-card'>
            <div class='service-icon'>
              <i class='fas fa-graduation-cap'></i>
            </div>
            <h3 class='service-title'>Training to Paper Publish</h3>
            <p class='text-muted'>Complete classes and guidance from basic training all the way to successfully publishing your research paper. Every step is covered by our experts.</p>
          </div>
        </div>
        <div class='col-md-4'>
          <div class='service-card'>
            <div class='service-icon'>
              <i class='fas fa-brain'></i>
            </div>
            <h3 class='service-title'>Machine Learning &amp; Applied Fields</h3>
            <p class='text-muted'>Specialized expertise in Machine Learning algorithms, deep learning, and their practical implementation across various applied research fields.</p>
          </div>
        </div>
        <div class='col-md-4'>
          <div class='service-card'>
            <div class='service-icon'>
              <i class='fas fa-database'></i>
            </div>
