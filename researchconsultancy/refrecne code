          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Main Content/Blog Section -->
  <section class='blog-section' id='blog'>
    <div class='container'>
      <h2 class='section-title'>Latest Research &amp; Articles</h2>
      
      <!-- Blogger Main Widget Area -->
      <b:section class='main-posts' id='main' maxwidgets='1' showaddelement='no'>
        <b:widget id='Blog1' locked='true' title='Blog Posts' type='Blog' version='2'>
          <b:includable id='main'>
            <b:if cond='data:view.isMultipleItems'>
              <!-- Index Page / Home View -->
              <div class='row'>
                <b:loop values='data:posts' var='post'>
                  <div class='col-lg-4 col-md-6'>
                    <article class='post-card'>
                      <!-- Post Image -->
                      <b:if cond='data:post.featuredImage'>
                        <img class='post-img' expr:alt='data:post.title' expr:src='data:post.featuredImage'/>
                      <b:else/>
                        <div class='post-img d-flex align-items-center justify-content-center bg-light text-muted' style='height: 200px;'>
                           <i class='fas fa-image fa-3x'></i>
                        </div>
                      </b:if>
                      
                      <div class='post-content'>
                        <div class='post-meta'>
                          <i class='far fa-calendar-alt me-1'></i> <b:eval expr='data:post.date format &quot;MMM dd, yyyy&quot;'/>
                          <span class='mx-2'>|</span>
                          <i class='far fa-folder me-1'></i> <b:if cond='data:post.labels'><b:loop values='data:post.labels' var='label'><a expr:href='data:label.url'><data:label.name/></a><b:if cond='!data:label.isLast'>, </b:if></b:loop><b:else/>Uncategorized</b:if>
                        </div>
                        <h3 class='post-title'>
                          <a expr:href='data:post.url'><data:post.title/></a>
                        </h3>
                        <p class='post-snippet mb-0 text-muted'>
                          <data:post.snippets.short/>...
                        </p>
                        <a class='read-more' expr:href='data:post.url'>Read Article <i class='fas fa-arrow-right ms-1'></i></a>
                      </div>
                    </article>
                  </div>
                </b:loop>
              </div>
              
              <!-- Pagination -->
              <b:include name='nextprev'/>
              
            <b:else/>
              <!-- Single Post View -->
              <div class='row justify-content-center'>
                <div class='col-lg-8'>
                  <b:loop values='data:posts' var='post'>
                    <article class='single-post bg-white p-4 p-md-5 rounded shadow-sm border'>
                      <h1 class='fw-bold mb-3'><data:post.title/></h1>
                      <div class='post-meta mb-4 pb-3 border-bottom'>
                        <i class='far fa-calendar-alt me-1'></i> <b:eval expr='data:post.date format &quot;MMM dd, yyyy&quot;'/>
                        <span class='mx-2'>|</span>
                        <i class='far fa-user me-1'></i> <data:post.author.name/>
                      </div>
                      
                      <div class='post-body'>
                        <data:post.body/>
                      </div>
                      
                      <b:if cond='data:post.labels'>
                        <div class='post-tags mt-5 pt-3 border-top'>
                          <strong>Labels:</strong> 
                          <b:loop values='data:post.labels' var='label'>
                            <a class='badge bg-light text-dark text-decoration-none ms-1' expr:href='data:label.url'><data:label.name/></a>
                          </b:loop>
                        </div>
                      </b:if>
                    </article>
                    
                    <!-- Comments Section -->
                    <b:if cond='data:post.allowComments'>
                       <div class='comments-area mt-5'>
                         <b:include data='post' name='comments'/>
                       </div>
                    </b:if>
                  </b:loop>
                </div>
              </div>
            </b:if>
          </b:includable>
          
          <b:includable id='nextprev'>
            <div class='blog-pager d-flex justify-content-between mt-4'>
              <b:if cond='data:newerPageUrl'>
                <a class='btn btn-outline-primary' expr:href='data:newerPageUrl' expr:title='data:messages.newerPosts'>
                  <i class='fas fa-chevron-left me-1'></i> Newer
                </a>
              <b:else/>
                <div></div>
              </b:if>
              
              <b:if cond='data:olderPageUrl'>
                <a class='btn btn-outline-primary' expr:href='data:olderPageUrl' expr:title='data:messages.olderPosts'>
                  Older <i class='fas fa-chevron-right ms-1'></i>
                </a>
              <b:else/>
                <div></div>
              </b:if>
            </div>
          </b:includable>

          <!-- Empty Includables to pass Blogger validation -->
          <b:includable id='commentDeleteIcon'></b:includable>
          <b:includable id='commentForm'></b:includable>
          <b:includable id='commentFormIframeSrc'></b:includable>
          <b:includable id='commentItem'></b:includable>
          <b:includable id='commentList'></b:includable>
          <b:includable id='commentPicker'></b:includable>
          <b:includable id='comments'></b:includable>
          <b:includable id='commentsTitle'></b:includable>
          <b:includable id='feedLinks'></b:includable>
          <b:includable id='feedLinksBody'></b:includable>
          <b:includable id='iframeComments'></b:includable>
          <b:includable id='inlineAd'></b:includable>
          <b:includable id='post'></b:includable>
          <b:includable id='postQuickEdit'></b:includable>
          <b:includable id='shareButtons'></b:includable>
          <b:includable id='status-message'></b:includable>
          <b:includable id='threadedCommentForm'></b:includable>
          <b:includable id='threadedCommentJs'></b:includable>
